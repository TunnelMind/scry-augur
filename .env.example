# Reuses the same scry Postgres on the Hetzner VPS. For local dev,
# tunnel from BEAST: ssh -fN -L 15432:127.0.0.1:5432 root@178.104.110.11
PG_URL=postgresql://scry:CHANGEME@127.0.0.1:15432/scry

# Cron cadence for source pulls. Each source runs its own loop;
# this is the master interval.
SOURCE_INTERVAL_MS=1800000   # 30 minutes

# Optional: User-Agent string to send when fetching public feeds.
# Some publishers (abuse.ch) request you identify yourself.
AUGUR_UA="scry-augur/0.1 (https://github.com/TunnelMind/scry-augur)"
